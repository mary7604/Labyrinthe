<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
  <meta charset="UTF-8">
  <title>Produit — Admin ShopElite</title>
  <link rel="stylesheet" th:href="@{/css/style.css}">
</head>
<body>

<nav class="navbar">
  <a class="navbar-brand" th:href="@{/}">
    Shop<span>Elite</span>
  </a>
  <div class="navbar-nav">
    <a th:href="@{/admin/produits}" class="nav-link">← Produits</a>
    <form th:action="@{/logout}" method="post" style="display:inline">
      <button type="submit" class="btn btn-secondary btn-sm">
        Déconnexion
      </button>
    </form>
  </div>
</nav>

<div class="container" style="max-width:700px">

  <div class="page-header">
    <h1 class="page-title">
      <span th:if="${produit != null and produit.id != null}">
        Modifier le <span>produit</span>
      </span>
      <span th:unless="${produit != null and produit.id != null}">
        Nouveau <span>produit</span>
      </span>
    </h1>
  </div>

  <div th:if="${success}" class="alert alert-success" th:text="${success}"></div>
  <div th:if="${error}" class="alert alert-error" th:text="${error}"></div>

  <div class="card">

    <!-- ACTION UNIQUE -->
    <form th:action="@{/admin/produits/sauvegarder}" method="post">

      <input type="hidden" name="id" th:value="${produit != null ? produit.id : ''}"/>

      <div class="form-group">
        <label class="form-label">Nom du produit *</label>
        <input type="text"
               name="nom"
               th:value="${produit != null ? produit.nom : ''}"
               class="form-control"
               required />
      </div>

      <div class="form-group">
        <label class="form-label">Description</label>
        <textarea name="description"
                  class="form-control"
                  rows="4"
                  th:text="${produit != null ? produit.description : ''}">
        </textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label class="form-label">Prix (€) *</label>
          <input type="number"
                 step="0.01"
                 name="prix"
                 th:value="${produit != null ? produit.prix : ''}"
                 class="form-control"
                 required />
        </div>

        <div class="form-group">
          <label class="form-label">Stock *</label>
          <input type="number"
                 name="stock"
                 th:value="${produit != null ? produit.stock : ''}"
                 class="form-control"
                 required />
        </div>
      </div>

      <div class="form-group">
        <label class="form-label">Catégorie</label>
        <select name="categorieId" class="form-control">
          <option value="">— Sans catégorie —</option>
          <option th:each="cat : ${categories}"
                  th:value="${cat.id}"
                  th:text="${cat.nom}"
                  th:selected="${produit != null 
                                and produit.categorie != null 
                                and produit.categorie.id == cat.id}">
          </option>
        </select>
      </div>

      <div style="display:flex;gap:1rem;margin-top:1.5rem">
        <button type="submit" class="btn btn-primary btn-lg">
          Enregistrer
        </button>
        <a th:href="@{/admin/produits}" class="btn btn-secondary btn-lg">
          Annuler
        </a>
      </div>

    </form>

  </div>
</div>

<footer>
  <span>ShopElite</span> — Projet AQL 2025/2026
</footer>

</body>
</html>